{
"manifest_version": 3,
"name": "Blur Mode",
"description": "Enable blur mode on Whatsapp Web to hide message and content.",
"version": "1.2.5",
"icons": {
  "16": "bos.png",
  "32": "bos.png",
  "48": "bos.png",
  "128": "bos.png"
},

"background": {
  "service_worker": "background.js",
  "type": "module"
},

"action": {
  "default_icon": "bos.png",
  "default_popup": "options.html"
},

"content_security_policy": {
  "extension_pages": "script-src 'self'; object-src 'self';",
  "sandbox": "sandbox allow-scripts allow-forms allow-popups allow-modals; script-src 'self' 'unsafe-inline' 'unsafe-eval'; child-src 'self';"
},

"content_scripts": [
  {
    "matches": ["https://web.whatsapp.com/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }
],

"host_permissions": ["https://web.whatsapp.com/*"],
"permissions": ["scripting", "activeTab", "webNavigation", "storage", "contextMenus"],
"commands": {
  "toggle-focus": {
    "suggested_key": {
      "default": "Ctrl+B",
      "mac": "Command+B"
  },
  "description": "Open Blur Mode Options"
  }
}
}
